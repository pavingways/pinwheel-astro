---
import { getEntry } from "astro:content";
import Config from "astro.config.mjs";
import Base from "@layouts/Base.astro";
import Banner from "@layouts/components/Banner.astro";
import Cta from "@layouts/partials/Cta.astro";
import ForCustomer from "@layouts/components/ForCustomer.astro";

const homepage = await getEntry("homepage", Astro.currentLocale ?? Config?.i18n?.defaultLocale ?? "de");
const { page, banner, banner2, for_customer } = homepage?.data;
---


<Base title={page.title} description={page.description}>
  <Banner banner={banner} />

  {for_customer?.map((content) => (
    <ForCustomer content={content} />
  ))}

