---
import Base from "@layouts/Base.astro";
import Cta from "@layouts/partials/Cta.astro";
import { markdownifyInline } from "@lib/utils/textConverter";
import { getEntryBySlug } from "astro:content";

const entry = await getEntryBySlug("pages", "services");
const { Content } = await entry.render();
const { services, audiences } = entry.data;
---

<Base
  title={entry.data.title}
  meta_title={entry.data.meta_title}
  description={entry.data.description}
  translation={entry.data.translation}
>
  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-10">
          <h1 class="mb-4" set:html={markdownifyInline(entry.data.title)} />
          <div class="content">
            <Content />
          </div>

          <!-- whole card is one link: bigger click target, no nested anchors -->
          <div class="row">
            {services?.map((service) => (
              <div class="mt-8 md:col-6">
                <a
                  href={service.url}
                  class="block h-full rounded-lg border border-border bg-white p-8 transition-all duration-200 hover:border-primary hover:shadow-lg"
                >
                  <h2 id={service.anchor} class="h4 text-dark">{service.title}</h2>
                  <p class="mt-4 text-text">{service.description}</p>
                </a>
              </div>
            ))}
          </div>

          {audiences && (
            <p class="mt-16">
              <strong>{audiences.title}</strong>{" "}
              {audiences.links.map((link, i) => (
                <>
                  <a class="text-primary hover:underline" href={link.url}>{link.label}</a>
                  {i < audiences.links.length - 1 && " · "}
                </>
              ))}
            </p>
          )}
        </div>
      </div>
    </div>
  </section>
  <Cta />
</Base>
