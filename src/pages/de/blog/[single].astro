---
import config from "@config/config.json";
import Base from "@layouts/Base.astro";
import BlogSingle from "@layouts/BlogSingle.astro";
import { getSinglePage } from "@lib/contentParser.astro";
import { blogPostingSchema, faqSchemaFromMarkdown } from "@lib/utils/schema";

export async function getStaticPaths() {
  const posts = await getSinglePage(config.settings.blog_folder, "de");

  const paths = posts.map((post) => ({
    params: {
      single: post.slug,
    },
    props: { post },
  }));
  return paths;
}

const { post } = Astro.props;
const { title, meta_title, description, image } = post.data;
const schemas = [
  blogPostingSchema({
    title,
    description,
    path: Astro.url.pathname,
    date: post.data.date,
    author: post.data.author,
    locale: "de",
    image,
  }),
];
// cornerstone posts may carry an FAQ section
const faq = faqSchemaFromMarkdown(post.body);
if (faq) schemas.push(faq);
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
  translation={post.data.translation}
  schemas={schemas}
>
  <BlogSingle post={post} />
</Base>
