---
import Base from "@layouts/Base.astro";
import { markdownify } from "@lib/utils/textConverter";
import { getEntry } from "astro:content";

const about = await getEntry("about", Astro.currentLocale);
const { Content } = await about.render();
---

<Base
  title={about.data.title}
  meta_title={about.data.meta_title}
  description={about.data.description}
  image={about.data.image}
  translation={about.data.translation}
>
  <section class="section">
    <div class="container">
      <h1 class="mb-4" set:html={markdownify(about.data.page_title ?? about.data.title)} />
      <Content />
    </div>
  </section>
</Base>
