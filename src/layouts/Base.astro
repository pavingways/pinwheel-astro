---
import TwSizeIndicator from "@components/TwSizeIndicator.astro";
import config from "@config/config.json";
import { getHreflangAlternates, getI18nStrings, withTrailingSlash } from "@lib/utils/i18n";
import { breadcrumbSchema, organizationSchema } from "@lib/utils/schema";
import { plainify } from "@lib/utils/textConverter";
import Footer from "@partials/Footer.astro";
import Header from "@partials/Header.astro";
import "@styles/main.scss";
// Poppins is self-hosted (GDPR: no requests to fonts.googleapis.com)
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/400-italic.css";
import "@fontsource/poppins/500.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/700.css";

// types for frontmatter
export interface Props {
  title?: string;
  meta_title?: string;
  page_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  translation?: string; // URL of this page in the other language (from frontmatter)
  schemas?: object[]; // page-specific JSON-LD nodes (Service, FAQPage, Person, ...)
}

// destructure front matter
const currentLocale = Astro.currentLocale;
const { title, meta_title, description, image, noindex, canonical, translation, schemas } = Astro.props;
const pagetitle = title ? title + config.site.titleaddon : config.site.title;
const i18n = getI18nStrings(currentLocale);
const metaDescription = plainify(description ?? i18n["meta_description"] ?? config.metadata.meta_description);

// hreflang links to the page's translation (only where one really exists):
// an explicit `translation` from frontmatter wins, same-slug pages pair automatically
const alternates = translation
  ? currentLocale === "de"
    ? { de: withTrailingSlash(Astro.url.pathname), en: withTrailingSlash(translation) }
    : { de: withTrailingSlash(translation), en: withTrailingSlash(Astro.url.pathname) }
  : getHreflangAlternates(Astro.url.pathname);
const isHome = alternates?.de === "/de/";

// JSON-LD: organization on every page, breadcrumbs on subpages, page nodes via props
const pathSegments = Astro.url.pathname.replace(/^\/+|\/+$/g, "").split("/");
const isSubPage = ["de", "en"].includes(pathSegments[0]) && pathSegments.length > 1;
const breadcrumbItems = isSubPage
  ? [
      { name: "Home", path: `/${pathSegments[0]}/` },
      // blog posts get the blog index as an intermediate level
      ...(pathSegments[1] === "blog" && pathSegments.length > 2
        ? [{ name: "Blog", path: `/${pathSegments[0]}/blog/` }]
        : []),
      { name: plainify(title ?? pagetitle), path: withTrailingSlash(Astro.url.pathname) },
    ]
  : null;
const jsonLd = [
  organizationSchema(),
  ...(breadcrumbItems ? [breadcrumbSchema(breadcrumbItems)] : []),
  ...(schemas ?? []),
];
---
<!DOCTYPE html>
<html lang={currentLocale}>
  <head>
    <link rel="shortcut icon" href={config.site.favicon} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' 'unsafe-eval' gc.zgo.at ajax.googleapis.com www.google.com www.gstatic.com www.youtube.com;" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#ffffff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000000"
    />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />
    <title>{plainify(pagetitle)}</title>
    {canonical && <link rel="canonical" href={canonical} item-prop="url" />}
    {alternates && (
      <>
        <link rel="alternate" hreflang="de" href={`${config.site.base_url}${alternates.de}`} />
        <link rel="alternate" hreflang="en" href={`${config.site.base_url}${alternates.en}`} />
      </>
    )}
    {isHome && (
      <link rel="alternate" hreflang="x-default" href={`${config.site.base_url}/`} />
    )}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`PavingWays Blog (${currentLocale === "de" ? "Deutsch" : "English"})`}
      href={`/${currentLocale ?? "de"}/blog/rss.xml`}
    />
    <meta name="description" content={metaDescription} />
    <meta name="author" content={config.metadata.meta_author} />
    <meta
      property="og:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title
      )}
    />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={currentLocale === "de" ? "de_CH" : "en_US"} />
    <meta
      property="og:url"
      content={`${config.site.base_url}/${Astro.url.pathname.replace("/", "")}`}
    />
    <meta
      name="twitter:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title
      )}
    />
    <meta name="twitter:description" content={metaDescription} />
    <meta
      property="og:image"
      content={`${config.site.base_url}${
        image ? image : config.metadata.meta_image
      }`}
    />
    <meta
      name="twitter:image"
      content={`${config.site.base_url}${
        image ? image : config.metadata.meta_image
      }`}
    />
    <meta name="twitter:card" content="summary_large_image" />
    {jsonLd.map((node) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}
  </head>
  <body>
    <TwSizeIndicator />
    <Header alternates={alternates} />
    <main id="main-content">
      <slot />
    </main>
    <Footer alternates={alternates} />
  </body>

  <script is:inline>
    // Remember the language of the page being viewed so that "/" can send
    // returning visitors straight to their language (see pages/index.astro)
    (function () {
      var lang = document.documentElement.lang;
      if (lang !== "de" && lang !== "en") return;
      try {
        window.localStorage.setItem("language_selection", lang);
      } catch (e) {}
      document.cookie =
        "language_selection=" + lang + "; max-age=31536000; path=/; SameSite=Lax";
    })();
  </script>

  {config.analytics?.goatcounter && (
    <>
      <script
        is:inline
        async
        data-goatcounter={`https://${config.analytics.goatcounter}.goatcounter.com/count`}
        src="https://gc.zgo.at/count.js"
      ></script>
      <script is:inline>
        // Conversion events: clicks on phone, e-mail and Calendly links.
        // GoatCounter is cookieless, so no consent banner is required.
        document.addEventListener("click", function (e) {
          var a = e.target && e.target.closest ? e.target.closest("a") : null;
          if (!a || !window.goatcounter || !window.goatcounter.count) return;
          var href = a.getAttribute("href") || "";
          var event =
            href.indexOf("tel:") === 0 ? "contact-phone"
            : href.indexOf("mailto:") === 0 ? "contact-email"
            : href.indexOf("calendly.com") !== -1 ? "contact-calendly"
            : null;
          if (event) window.goatcounter.count({ path: event, title: event, event: true });
        });
      </script>
    </>
  )}

</html>
