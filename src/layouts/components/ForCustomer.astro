---
import { markdownify, markdownifyInline } from "@lib/utils/textConverter";
import Comic from "./Comic.astro";
import CtaButton from "./CtaButton.astro";

const { content } = Astro.props;
const { title, description, comic, cta } = content;
---


<section class="section mt-32">
  <div class="container">
    <div class="row">
      <!-- h2 keeps the document outline intact under the page h1; .h3 keeps the previous size -->
      <h2 class="h3" set:html={markdownifyInline(title)} />
      <div class="mt-6">
        <div set:html={markdownify(description)} />
      </div>
    </div>
    {comic && (
      <div class="row justify-center">
        <Comic content={comic} alignment="left" />
      </div>
    )}
    {cta && (
      <div class="text-center mt-16">
        <CtaButton content={cta} />
      </div>
    )}
  </div>
</section>
